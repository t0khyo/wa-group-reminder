# Database Configuration
# For Docker Compose, use the service name 'gigi-db' as the host
DATABASE_URL="postgresql://postgres:postgres@gigi-db:5432/gigi_db?schema=public"

# Database Credentials
# WARNING: If you uncomment the port mapping in docker-compose.yml,
# change these to strong passwords for security!
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="gigi_db"

# Database Port (only needed if you uncomment port mapping in docker-compose.yml)
# DB_PORT="5437"

# AI Provider Configuration
# Options: "openai" or "gemini"
AI_PROVIDER="gemini"

# OpenAI Configuration (if using OpenAI)
OPENAI_API_KEY="xyz"
AI_MODEL="gpt-4"

# Gemini Configuration (if using Gemini)
GEMINI_API_KEY="xyz"
GEMINI_MODEL="gemini-2.5-flash"

# Logging Configuration
# Options: "debug", "info", "warn", "error"
LOG_LEVEL="info"

# Node Environment
NODE_ENV="production"

# Timezone Configuration
# Set this to match the timezone of your users
# All reminder times will be interpreted in this timezone
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
REMINDER_TIMEZONE="Asia/Kuwait"
