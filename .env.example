# Database
DATABASE_URL="postgresql://postgres:postgres@gigi-db:5432/gigi_db?schema=public"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="gigi_db"

# AI Provider ("gemini" or "openai")
AI_PROVIDER="gemini"

# Gemini
GEMINI_API_KEY="xyz"
GEMINI_MODEL="gemini-2.5-flash"

# OpenAI
OPENAI_API_KEY="xyz"
AI_MODEL="gpt-4"

# Audio Podcast
NEWS_TTS_SPEAKING_RATE="1.05"

# App
REMINDER_TIMEZONE="Asia/Kuwait"
LOG_LEVEL="info"
NODE_ENV="production"